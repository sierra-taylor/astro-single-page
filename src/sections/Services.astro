---
import Icon from "@/components/Icon.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import type {
  Icon as IconType,
  ServicesData,
} from "@/config/landing.interface";

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
---

<section id="services" class="flex flex-col">
  <SectionTitle>
    {data.title}
  </SectionTitle>
  <div class="grid md:grid-cols-2 justify-items-center">
    {
      data.services.map((service) => (
        <div class="card">
          <figure>
            <Icon icon={service.icon as IconType} />
          </figure>
          <div class="card-body">
            <h2 class="card-title">{service.title}</h2>
            <p>{service.description}</p>
            <div class="card-actions">
              <button class="btn btn-primary">Buy Now</button>
            </div>
          </div>
        </div>
        // <article class="flex gap-x-6 md:gap-x-12 md:w-[550px]">
        //   <div>
        //     <IconWrapper>
        //       <Icon icon={service.icon as IconType} />
        //     </IconWrapper>
        //   </div>
        //   <section>
        //     <h3 class="text-xl font-medium md:text-4xl mb-3">
        //       {service.title}
        //     </h3>
        //     <p class="text-pretty opacity-90 md:text-lg">
        //       {service.description}
        //     </p>
        //   </section>
        // </article>
      ))
    }
  </div>
</section>
