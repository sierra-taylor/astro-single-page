---
import Icon from "@/components/Icon.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import type { BrandsData, Icon as IconType } from "@/config/landing.interface";

interface Props {
  data: BrandsData;
}

const { data } = Astro.props;
---

<section id="brands" class="flex flex-col justify-between md:flex-row w-full">
  <div class="w-11/12 flex flex-col">
    <SectionTitle>
      {data.title}
    </SectionTitle>
    <p class="text-lg text-center md:text-start md:text-xl">
      {data.description}
    </p>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 w-full justify-items-center">
    {
      data.brands.map((brand) => (
        <div class="md:grayscale hover:grayscale-0 hover:scale-110 transition">
          <a href={brand.href} title={brand.icon} target="_blank">
            <Icon icon={brand.icon as IconType} />
          </a>
        </div>
      ))
    }
  </div>
</section>
