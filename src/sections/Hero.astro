---
import { getImage } from "astro:assets";
interface Props {
  data: {
    title: string;
    image: string;
    subTitle: string;
    primaryCta: string;
    secondaryCta: string;
    highlightedTitle?: string;
  };
}
const { data } = Astro.props;
let bgImage = await getImage({
  src: data.image,
  width: 1920,
  height: 1080,
  format: "webp",
});
if (bgImage.src.includes(")")) {
  bgImage.src = bgImage.src.slice(0, -1);
}
---

<section
  id="hero"
  class="hero min-h-screen"
  style={`background-image: url('${bgImage.src}')`}
>
  {data.image && <div class="hero-overlay" />}
  <div class="hero-content text-center">
    <div class="max-w-md">
      <h1 class="text-4xl text-center font-semibold md:text-6xl">
        {data.title}
        <span class="text-primary"> {data.highlightedTitle} </span>
      </h1>

      <h2 class="mt-10 text-lg text-center opacity-80 md:text-2xl">
        {data.subTitle}
      </h2>
      <div class="flex justify-evenly mt-10">
        <a class="btn" href="#contact">{data.primaryCta}</a>
        <button class="btn">{data.secondaryCta}</button>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #hero-section {
    opacity: 0;
    animation: fadeIn 0.8s ease-in-out forwards;
  }
</style>
