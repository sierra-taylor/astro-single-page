---
import CheckIcon from "@/assets/images/icons/commons/CheckIcon.astro";
import ConfigIcon from "@/assets/images/icons/commons/ConfigIcon.astro";
import DevIcon from "@/assets/images/icons/commons/DevIcon.astro";
import FileIcon from "@/assets/images/icons/commons/FileIcon.astro";
import PlanetIcon from "@/assets/images/icons/commons/PlanetIcon.astro";
import FacebookIcon from "@/assets/images/icons/socials/FacebookIcon.astro";
import GithubIcon from "@/assets/images/icons/socials/GithubIcon.astro";
import InstagramIcon from "@/assets/images/icons/socials/InstagramIcon.astro";
import TwitterIcon from "@/assets/images/icons/socials/TwitterIcon.astro";
import NetlifyIcon from "@/assets/images/icons/techs/NetlifyIcon.astro";
import ReactIcon from "@/assets/images/icons/techs/ReactIcon.astro";
import SolidIcon from "@/assets/images/icons/techs/SolidIcon.astro";
import SvelteIcon from "@/assets/images/icons/techs/SvelteIcon.astro";
import VercelIcon from "@/assets/images/icons/techs/VercelIcon.astro";
import VueIcon from "@/assets/images/icons/techs/VueIcon.astro";
import type { Icon } from "@/config/landing.interface";

interface Props {
  icon: Icon;
  class?: string;
}

const { icon, class: className } = Astro.props;

const icons = [
  ConfigIcon,
  DevIcon,
  FileIcon,
  PlanetIcon,
  CheckIcon,
  FacebookIcon,
  GithubIcon,
  InstagramIcon,
  TwitterIcon,
  ReactIcon,
  SvelteIcon,
  VueIcon,
  NetlifyIcon,
  SolidIcon,
  VercelIcon,
];

let figures: Record<string, (_props: Record<string, unknown>) => unknown> = {};

icons.map((item) => {
  figures[item.name] = item;
});

const Figure = figures[icon];
---

{Figure ? <Figure class:list={[className]} /> : <p>Icon not found</p>}
